rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Shared helpers ────────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    // Safe isAdmin: uses exists() guard + .get() with default to avoid errors
    // if the caller's document is missing.  Also split out from isOwner checks
    // on /users so that reading your own doc never triggers a get() on itself.
    function isAdmin() {
      return isAuthed()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function onlyUpdatingField(fieldName) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([fieldName]);
    }

    // ── users ─────────────────────────────────────────────────────────────
    // Split into two allow-read rules so a user reading their OWN document
    // never triggers the get() inside isAdmin() — that circular get() was
    // causing "Missing or insufficient permissions" on every login.
    match /users/{uid} {
      allow read:  if isOwner(uid);            // self-read — no get() involved
      allow read:  if isAdmin();               // admin read — separate rule
      allow write: if isOwner(uid) || isAdmin();
    }

    // ── directory ─────────────────────────────────────────────────────────
    // Allow users to create/update their own directory entry (needed during
    // registration — previously "write: if isAdmin()" blocked all signups).
    match /directory/{docId} {
      allow read:  if isAuthed();
      allow write: if isOwner(docId) || isAdmin();
    }

    // ── activities ────────────────────────────────────────────────────────
    // Authenticated users can update the `volunteers` field only.
    match /activities/{docId} {
      allow read:   if isAuthed();
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isAuthed() && onlyUpdatingField('volunteers'));
      allow delete: if isAdmin();
    }

    // ── chat ──────────────────────────────────────────────────────────────
    match /chat/{msgId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if false;
      allow delete: if isAdmin()
                    || (isAuthed() && resource.data.uid == request.auth.uid);
    }

    // ── announcements ─────────────────────────────────────────────────────
    match /announcements/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ── schedule ──────────────────────────────────────────────────────────
    match /schedule/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ── history ───────────────────────────────────────────────────────────
    match /history/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ── settings ──────────────────────────────────────────────────────────
    // Stores event details (date, time, location, theme). All logged-in
    // users can read; only admin can write.
    match /settings/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ── vendors ───────────────────────────────────────────────────────────
    match /vendors/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ── poll ──────────────────────────────────────────────────────────────
    // Each document ID = uid. Users can read/write only their own vote.
    // Admins can read all documents to tally results.
    match /poll/{uid} {
      allow read:  if isOwner(uid);   // user sees their own saved selection
      allow read:  if isAdmin();      // admin reads all for results view
      allow write: if isOwner(uid);   // users submit/update their own vote only
    }

  }
}
