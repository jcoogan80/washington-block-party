rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Shared helpers ────────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function onlyUpdatingField(fieldName) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([fieldName]);
    }

    // ── users ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    // ── directory ─────────────────────────────────────────────────────────
    match /directory/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ── activities ────────────────────────────────────────────────────────
    // Authenticated users can update the `volunteers` field only.
    match /activities/{docId} {
      allow read:   if isAuthed();
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isAuthed() && onlyUpdatingField('volunteers'));
      allow delete: if isAdmin();
    }

    // ── chat ──────────────────────────────────────────────────────────────
    match /chat/{msgId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if false;
      allow delete: if isAdmin()
                    || (isAuthed() && resource.data.uid == request.auth.uid);
    }

    // ── announcements ─────────────────────────────────────────────────────
    match /announcements/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ── schedule ──────────────────────────────────────────────────────────
    match /schedule/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ── history ───────────────────────────────────────────────────────────
    match /history/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }
  }
}
